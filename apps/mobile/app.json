{
  "expo": {
    "name": "TetherCode",
    "slug": "tethercode",
    "owner": "davidparks8s-team",
    "scheme": "tethercode",
    "version": "0.1.0",
    "userInterfaceStyle": "automatic",
    "orientation": "portrait",
    "icon": "./assets/brand/app-icon.png",
    "splash": {
      "image": "./assets/brand/splash-icon-white.png",
      "resizeMode": "contain",
      "backgroundColor": "#0C0F12"
    },
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSAppTransportSecurity": {
          "NSAllowsArbitraryLoads": false,
          "NSAllowsArbitraryLoadsInWebContent": true,
          "NSAllowsLocalNetworking": true
        }
      },
      "bundleIdentifier": "com.davidparks.tethercode"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/brand/adaptive-icon.png",
        "backgroundColor": "#0C0F12"
      },
      "permissions": [
        "android.permission.CAMERA"
      ],
      "package": "com.davidparks.tethercode"
    },
    "web": {
      "favicon": "./assets/brand/favicon.png"
    },
    "platforms": [
      "ios",
      "android",
      "web"
    ],
    "experiments": {
      "reactCompiler": true
    },
    "plugins": [
      "./plugins/withAndroidCleartextTraffic",
      [
        "expo-camera",
        {
          "cameraPermission": "TetherCode uses the camera to scan bridge pairing QR codes and capture photos you want to attach to a chat."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "TetherCode uses your photo library so you can choose an image from your phone and attach it to a chat prompt or workflow sent to your own host bridge.",
          "cameraPermission": "TetherCode uses the camera to scan bridge pairing QR codes and capture photos you want to attach to a chat."
        }
      ],
      "expo-secure-store",
      "expo-notifications"
    ],
    "extra": {
      "eas": {
        "projectId": "dc4bb45d-72cf-4c82-8fcd-f841b1ef6c71"
      }
    }
  }
}
