BRIDGE_HOST=127.0.0.1
BRIDGE_PORT=8787
BRIDGE_PREVIEW_HOST=127.0.0.1
BRIDGE_PREVIEW_PORT=8788
BRIDGE_WORKDIR=/path/to/target/repo
ACP_AGENT_MANIFEST=/path/to/target/repo/.clawdex/agents.json
ACP_AGENT_ROOTS=/path/to/target/repo/.clawdex/agents
ACP_INITIALIZE_TIMEOUT_MS=15000
BRIDGE_AUTH_TOKEN=change-me
BRIDGE_ALLOW_INSECURE_NO_AUTH=false
BRIDGE_NO_AUTH_ALLOWED_ORIGINS=
BRIDGE_ALLOW_QUERY_TOKEN_AUTH=true
BRIDGE_ALLOW_OUTSIDE_ROOT_CWD=true
# Generic terminal execution is deny-all unless explicit argument-aware policies are enabled.
# Supported policies: pwd,ls,cat. Git is only available through bridge/git RPC methods.
BRIDGE_TERMINAL_EXEC_POLICIES=
BRIDGE_WS_MAX_FRAME_BYTES=33554432
BRIDGE_WS_MAX_MESSAGE_BYTES=33554432
BRIDGE_WS_PER_CLIENT_IN_FLIGHT=16
BRIDGE_WS_GLOBAL_IN_FLIGHT=128
BRIDGE_CHATGPT_ACCESS_TOKEN=
BRIDGE_CHATGPT_ACCOUNT_ID=
BRIDGE_CHATGPT_PLAN_TYPE=
